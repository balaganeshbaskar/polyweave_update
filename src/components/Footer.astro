---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const siteLinks = [
  { href: `${base}/`, label: 'Home' },
  { href: `${base}/about`, label: 'About' },
  { href: `${base}/services`, label: 'Services' },
  { href: `${base}/defence`, label: 'Defence' },
  { href: `${base}/contact`, label: 'Contact' }
];

const sourcingLinks = [
  { href: `${base}/hdpe-and-twines-supplier-india`, label: 'HDPE & Twines Supplier India' },
  { href: `${base}/fishing-net-manufacturers-india`, label: 'Fishing Net Manufacturers India' },
  { href: `${base}/nylon-net-supplier-india`, label: 'Nylon Fishing Net Supplier India' },
  { href: `${base}/rope-suppliers-india`, label: 'Rope Suppliers India' },
  { href: `${base}/sports-nets-manufacturer-india`, label: 'Sports Nets Manufacturer India' }
];
---

<footer class="footer">
  <div class="footer-inner max-w-content page-gutter">
    <!-- Brand -->
    <div class="footer-brand">
      <div class="footer-logo">POLYWEAVE</div>
      <p class="footer-tagline">Sourcing from India,<br />made clearer.</p>
    </div>

    <!-- Site -->
    <div class="footer-col">
      <button class="footer-accordion-trigger" aria-expanded="false">
        <h5 class="footer-heading">SITE</h5>
        <span class="footer-accordion-arrow" aria-hidden="true">▾</span>
      </button>
      <div class="footer-accordion-content">
        <ul class="footer-links">
          {siteLinks.map(link => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Sourcing -->
    <div class="footer-col">
      <button class="footer-accordion-trigger" aria-expanded="false">
        <h5 class="footer-heading">SOURCING</h5>
        <span class="footer-accordion-arrow" aria-hidden="true">▾</span>
      </button>
      <div class="footer-accordion-content">
        <ul class="footer-links">
          {sourcingLinks.map(link => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Contact -->
    <div class="footer-col">
      <button class="footer-accordion-trigger" aria-expanded="false">
        <h5 class="footer-heading">CONTACT</h5>
        <span class="footer-accordion-arrow" aria-hidden="true">▾</span>
      </button>
      <div class="footer-accordion-content">
        <ul class="footer-links">
          <li><a href="mailto:sourcing@polyweave.net">sourcing@polyweave.net</a></li>
          <li>India · Europe</li>
          <li class="footer-cta">
            <a href={`${base}/contact`} class="link-cta">send your price →</a>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <div class="footer-bottom max-w-content page-gutter">
    <p>&copy; {new Date().getFullYear()} Polyweave. All rights reserved.</p>
    <div class="footer-legal">
      <a href={`${base}/privacy`}>Privacy</a>
      <a href={`${base}/cookies`}>Cookies</a>
    </div>
  </div>
</footer>

<script>
  document.querySelectorAll('.footer-accordion-trigger').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
    });
  });
</script>

<style>
  .footer {
    background: var(--color-paper);
    border-top: 3px solid var(--color-ink);
    margin-top: 48px;
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
    padding-top: 48px;
    padding-bottom: 48px;
  }

  @media (min-width: 768px) {
    .footer-inner {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .footer-inner {
      grid-template-columns: 1.5fr repeat(3, 1fr);
      gap: 24px;
    }
  }

  .footer-logo {
    font-family: var(--font-meta);
    font-size: 14px;
    letter-spacing: 2px;
    margin-bottom: 8px;
  }

  .footer-tagline {
    font-family: var(--font-display);
    font-size: 28px;
    line-height: 1.1;
    color: var(--color-ink);
    margin: 0;
  }

  .footer-heading {
    font-family: var(--font-meta);
    font-size: 20px;
    letter-spacing: 1.5px;
    color: var(--color-sea);
    margin: 0 0 14px;
    text-transform: uppercase;
  }

  .footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .footer-links a {
    font-family: var(--font-body);
    font-size: 15px;
    color: var(--color-ink);
    text-decoration: none;
    transition: color 180ms cubic-bezier(.2,.6,.2,1);
  }

  .footer-links a:hover {
    color: var(--color-sea);
  }

  .footer-links li {
    font-family: var(--font-body);
    font-size: 15px;
    color: var(--color-ink);
  }

  .footer-cta {
    margin-top: 12px;
  }

  .link-cta {
    font-family: var(--font-display);
    font-size: 16px;
    color: var(--color-ink);
  }

  /* Accordion */
  .footer-accordion-trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    background: none;
    border: none;
    padding: 0;
    color: inherit;
    font: inherit;
  }

  .footer-accordion-trigger .footer-heading {
    margin: 0 0 14px;
  }

  .footer-accordion-arrow {
    display: none;
    font-size: 24px;
    color: var(--color-sea);
    transition: transform 200ms ease;
  }

  .footer-accordion-trigger[aria-expanded="true"] .footer-accordion-arrow {
    transform: rotate(180deg);
  }

  .footer-accordion-content {
    overflow: hidden;
  }

  @media (min-width: 1024px) {
    .footer-accordion-trigger {
      cursor: default;
      pointer-events: none;
    }
    .footer-accordion-content {
      max-height: none !important;
    }
  }

  @media (max-width: 1023px) {
    .footer-logo {
      font-size: 20px;
    }
    .footer-accordion-trigger {
      cursor: pointer;
      padding: 12px 0;
      border-bottom: 1px dashed var(--color-ink-soft);
    }
    .footer-accordion-trigger .footer-heading {
      margin: 0;
    }
    .footer-accordion-arrow {
      display: block;
    }
    .footer-accordion-content {
      max-height: 0;
      transition: max-height 250ms ease;
    }
    .footer-accordion-trigger[aria-expanded="true"] + .footer-accordion-content {
      max-height: 400px;
      padding-bottom: 12px;
    }
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 24px;
    padding-bottom: 24px;
    border-top: 1.25px dashed var(--color-ink-soft);
  }

  .footer-bottom p {
    font-family: var(--font-meta);
    font-size: 11px;
    color: var(--color-ink-faint);
    margin: 0;
  }

  .footer-legal {
    display: flex;
    gap: 16px;
  }

  .footer-legal a {
    font-family: var(--font-meta);
    font-size: 11px;
    color: var(--color-ink-faint);
    text-decoration: none;
  }

  .footer-legal a:hover {
    color: var(--color-sea);
  }
</style>