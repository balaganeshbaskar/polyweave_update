---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import StickyForm from '../components/StickyForm.astro';
import SectionTag from '../components/SectionTag.astro';
import InfiniteGrid from '../components/InfiniteGrid.astro';

const pageTitle = 'HDPE, PP & Nylon Twine Supplier India | Polyweave';
const pageDescription = 'Source HDPE, PP and nylon twines from Indian manufacturers. Polyweave helps European buyers find the right twine construction, size, packing and price.';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "HDPE, PP & Nylon Twine Sourcing from India",
  "description": "Source HDPE, PP and nylon twines from Indian manufacturers with the right construction, size, packing and price.",
  "provider": { "@type": "Organization", "name": "Polyweave", "url": "https://polyweave.net" },
  "areaServed": ["Spain", "Italy", "Portugal", "Germany", "France", "Norway", "Europe"],
  "serviceType": "Sourcing Service"
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonicalUrl="/hdpe-and-twines-supplier-india" schema={serviceSchema}>
  <Nav active="home" />

  <main id="main-content">
    <!-- Hero -->
    <section class="hero section-padding" style="position:relative;overflow:hidden">
      <InfiniteGrid hoverEffect={true} opacity={0.03} hoverOpacity={0.6} hoverRadius={300} />
      <div style="position:relative;z-index:1">
        <div class="max-w-content page-gutter">
          <div class="hero-eyebrow tag">SOURCING · INDIA → EUROPE</div>
          <h1 class="hero-title text-display-1">
            HDPE, PP & Nylon Twine <span class="highlight-navy">Supplier</span> <span class="highlight-sea">from India</span>.
          </h1>
          <div class="hero-intro">
            <p>Polyweave helps buyers source HDPE, PP and nylon twines from Indian manufacturers with the right construction, size, packing and price.</p>
            <p>We work with braided, twisted, coreless and standard twines across fishing, net-making, agricultural and industrial applications.</p>
            <p>For PP and HDPE twines, we can source sizes up to around 4 mm. For nylon braided twines, larger sizes can also be developed depending on the application and buyer requirement.</p>
          </div>
          <div class="europe-note tag">WORKING WITH BUYERS ACROSS EUROPE · ES · IT · PT · DE · NO</div>
        </div>
      </div>
    </section>

    <!-- What Matters -->
    <section class="what-matters section-padding">
      <div class="max-w-content page-gutter">
        <SectionTag num="02" label="WHAT BUYERS USUALLY NEED TO GET RIGHT" />
        <h2 class="text-h2">It isn't only about price per kg.</h2>
        <p class="text-body-lg">
          The construction, thickness, cone quality, winding, colour, packing and final application all affect the actual usability of the product.
        </p>
        <p class="text-body">
          Many buyers face issues with inconsistent thickness, wrong construction, poor finishing, weak packing or cones that do not work properly during production.
        </p>
        <p class="text-body">
          Polyweave helps check the requirement clearly before approaching suppliers, so buyers are not comparing random offers.
        </p>
      </div>
    </section>

    <!-- What to Send -->
    <section class="what-to-send section-padding">
      <div class="max-w-content page-gutter">
        <SectionTag num="03" label="WHAT TO SEND US" />
        <h2 class="text-h2">Send your spec — or your sample.</h2>
        <ul class="send-list">
          <li>Twine type, size, material, colour, packing requirement, quantity and current supplier price.</li>
        </ul>
        <p class="text-body">If you already have a sample or photo, even better. We can check whether Indian manufacturers can match the product and offer a better sourcing route.</p>
      </div>
    </section>

    <!-- Final CTA -->
    <section class="final-cta section-padding bg-sea-blue">
      <div class="max-w-content page-gutter">
        <div class="cta-content">
          <h2 class="cta-title text-paper">Send your current twine spec and price.</h2>
          <p class="text-paper-op-90">We'll review and respond with what's realistically possible from India.</p>
          <div class="cta-button">
            <a href={`${base}/contact`} class="btn-primary btn-paper">
              SEND YOUR PRICE <span class="btn-arrow">→</span>
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <StickyForm showBookCall={false} />
  <Footer />
</BaseLayout>

<style>
  .hero { min-height: 50vh; }
  .hero-eyebrow { margin-bottom: 16px; }
  .hero-title { margin-bottom: 24px; }
  .hero-intro { max-width: 720px; }
  .hero-intro p { font-size: 18px; line-height: 1.6; margin-bottom: 12px; color: var(--color-ink-soft); }
  .hero-intro p:last-child { margin-bottom: 0; }
  .europe-note { margin-top: 20px; }

  /* What Matters */
  .what-matters h2 { margin-bottom: 16px; }
  .what-matters p { max-width: 720px; color: var(--color-ink-soft); }
  .what-matters p.text-body-lg { margin-bottom: 12px; }
  .what-matters p.text-body { margin-bottom: 8px; }
  .what-matters p.text-body:last-child { margin-bottom: 0; }

  /* What to Send */
  .what-to-send h2 { margin-bottom: 16px; }
  .send-list { list-style: none; padding: 0; margin: 0 0 16px; max-width: 720px; }
  .send-list li { font-size: 18px; line-height: 1.6; color: var(--color-ink-soft); padding: 10px 0; border-bottom: 1px dashed rgba(20,35,58,0.2); }
  .what-to-send p { color: var(--color-ink-soft); }

  /* Final CTA */
  .cta-content { text-align: center; max-width: 600px; margin: 0 auto; }
  .cta-title { font-family: var(--font-display); font-size: 32px; margin: 0 0 12px; }
  .cta-content p { font-size: 18px; margin: 0 0 24px; }
  .cta-button { display: inline-block; }
  .btn-paper { background: var(--color-paper); color: var(--color-ink); }
  .btn-paper:hover { background: var(--color-paper-2); }
</style>
