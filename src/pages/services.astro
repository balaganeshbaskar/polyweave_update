---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import StickyForm from '../components/StickyForm.astro';
import SectionTag from '../components/SectionTag.astro';

const pageTitle = 'Services · How Polyweave sources from India';
const pageDescription = 'What we do, how we work, and how we\'re priced. €0 upfront for buyers — Polyweave aligns incentives with manufacturers, not buyers.';

const categories = [
  { label: 'HDPE Twine', href: '/hdpe-twine-supplier-india' },
  { label: 'Fishing Nets', href: '/fishing-net-manufacturers-india' },
  { label: 'Nylon Nets', href: '/nylon-net-supplier-india' },
  { label: 'Ropes', href: '/rope-suppliers-india' },
  { label: 'Jute Yarn', href: '/jute-yarn-exporters-india' }
];
---

<BaseLayout title={pageTitle} description={pageDescription} canonicalUrl="/services">
  <Nav active="services" />

  <main id="main-content">
    <!-- Hero -->
    <section class="hero section-padding">
      <div class="max-w-content page-gutter">
        <div class="hero-eyebrow tag">SERVICES · WHAT WE DO</div>
        <h1 class="hero-title text-display-1">
          What we <span class="highlight-sea">do</span>.
        </h1>
        <p class="hero-lede text-body-lg">
          We help companies source from India more efficiently.
        </p>
      </div>
    </section>

    <!-- You come to us when -->
    <section class="you-come section-padding">
      <div class="max-w-content page-gutter">
        <SectionTag label="YOU COME TO US WHEN" />

        <div class="you-come-list">
          <div class="list-item">
            <span class="list-num">01</span>
            <p>You feel you are overpaying.</p>
          </div>
          <div class="list-item">
            <span class="list-num">02</span>
            <p>You want alternative suppliers.</p>
          </div>
          <div class="list-item">
            <span class="list-num">03</span>
            <p>You want to explore India but reduce risk.</p>
          </div>
          <div class="list-item">
            <span class="list-num">04</span>
            <p>You want to compare your current supplier price.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- How we work (navy band per handoff) -->
    <section class="how-we-work section-padding bg-navy">
      <div class="max-w-content page-gutter">
        <SectionTag label="HOW WE WORK" />

        <div class="work-cards-grid">
          <div class="work-card">
            <div class="work-num text-paper-op-65">01</div>
            <h3 class="work-title text-paper">Understand</h3>
            <p class="work-desc text-paper-op-85">You share your requirement, product, supplier, or current price.</p>
          </div>
          <div class="work-card">
            <div class="work-num text-paper-op-65">02</div>
            <h3 class="work-title text-paper">Source</h3>
            <p class="work-desc text-paper-op-85">We identify suitable manufacturers in India.</p>
          </div>
          <div class="work-card">
            <div class="work-num text-paper-op-65">03</div>
            <h3 class="work-title text-paper">Align</h3>
            <p class="work-desc text-paper-op-85">We handle price discussions, specifications, and feasibility.</p>
          </div>
          <div class="work-card">
            <div class="work-num text-paper-op-65">04</div>
            <h3 class="work-title text-paper">Support</h3>
            <p class="work-desc text-paper-op-85">We help move the deal forward with clarity.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Pricing (sea-blue band per handoff) -->
    <section class="pricing section-padding bg-sea-blue">
      <div class="max-w-content page-gutter">
        <div class="pricing-box">
          <h2 class="pricing-headline">€0 upfront for buyers.</h2>
          <p class="pricing-desc">
            Polyweave works closely with suppliers and aligns incentives based on successful transactions.
          </p>
          <p class="pricing-sub">
            You only see results, not invoices for exploration.
          </p>
        </div>
      </div>
    </section>

    <!-- Categories -->
    <section class="categories section-padding">
      <div class="max-w-content page-gutter">
        <SectionTag label="WHERE WE WORK MOST" />

        <div class="category-chips">
          {categories.map(cat => (
            <a href={cat.href} class="category-chip">{cat.label}</a>
          ))}
          <span class="category-chip category-adjacent">+ adjacent categories</span>
        </div>
      </div>
    </section>

    <!-- Final CTA -->
    <section class="final-cta section-padding">
      <div class="max-w-content page-gutter">
        <h2 class="text-h2">Send your current price.</h2>
        <p class="text-body-lg">We'll tell you what's possible.</p>
        <div class="cta-button">
          <a href="/contact" class="btn-primary">
            SEND YOUR PRICE <span class="btn-arrow">→</span>
          </a>
        </div>
      </div>
    </section>
  </main>

  <StickyForm showBookCall={true} />
  <Footer />
</BaseLayout>

<style>
  /* Hero */
  .hero {
    min-height: 50vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .hero-eyebrow {
    margin-bottom: 16px;
  }

  .hero-title {
    margin-bottom: 20px;
  }

  .hero-lede {
    max-width: 720px;
    color: var(--color-ink-soft);
  }

  .highlight-sea {
    color: var(--color-sea);
  }

  /* You come to us when */
  .you-come-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-width: 600px;
  }

  .list-item {
    display: flex;
    align-items: baseline;
    gap: 16px;
    padding: 12px 0;
    border-bottom: 1px dashed rgba(20,35,58,0.2);
  }

  .list-num {
    font-family: var(--font-meta);
    font-size: 12px;
    color: var(--color-sea);
    min-width: 24px;
  }

  .list-item p {
    margin: 0;
    font-size: 18px;
  }

  /* How we work */
  .work-cards-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 18px;
  }

  @media (min-width: 768px) {
    .work-cards-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .work-cards-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .work-card {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .work-num {
    font-family: var(--font-meta);
    font-size: 10px;
    letter-spacing: 1.5px;
    color: rgba(247,244,238,0.65);
  }

  .work-title {
    font-family: var(--font-display);
    font-size: 24px;
    margin: 0;
    color: var(--color-paper);
  }

  .work-desc {
    font-size: 15px;
    color: rgba(247,244,238,0.85);
    margin: 0;
  }

  /* Pricing */
  .pricing-box {
    text-align: center;
    padding: 40px;
  }

  .pricing-headline {
    font-family: var(--font-display);
    font-size: 36px;
    color: var(--color-paper);
    margin: 0 0 16px;
  }

  .pricing-desc {
    font-size: 18px;
    color: var(--color-paper);
    margin: 0 0 8px;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .pricing-sub {
    font-size: 16px;
    color: var(--color-sea-soft);
    margin: 0;
  }

  /* Categories */
  .category-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .category-chip {
    font-family: var(--font-body);
    font-size: 16px;
    padding: 8px 16px;
    border: 1.5px solid var(--color-ink);
    border-radius: var(--radius-sketch);
    text-decoration: none;
    color: var(--color-ink);
    transition: background 180ms cubic-bezier(.2,.6,.2,1),
                color 180ms cubic-bezier(.2,.6,.2,1);
  }

  .category-chip:hover {
    background: rgba(46,111,142,0.08);
    color: var(--color-sea);
  }

  .category-adjacent {
    border-color: var(--color-ink-faint);
    color: var(--color-ink-faint);
    cursor: default;
  }

  .category-adjacent:hover {
    background: transparent;
    color: var(--color-ink-faint);
  }

  /* Final CTA */
  .final-cta {
    text-align: center;
  }

  .final-cta h2 {
    margin-bottom: 12px;
  }

  .final-cta p {
    margin-bottom: 24px;
    color: var(--color-ink-soft);
  }
</style>