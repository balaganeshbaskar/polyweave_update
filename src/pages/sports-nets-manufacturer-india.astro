---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import StickyForm from '../components/StickyForm.astro';
import SectionTag from '../components/SectionTag.astro';
import InfiniteGrid from '../components/InfiniteGrid.astro';

const pageTitle = 'Sports Nets & Football Nets Manufacturer India | Polyweave';
const pageDescription = 'Source sports nets, football nets, and custom netting from Indian manufacturers. Polyweave helps European buyers import sports netting with better pricing and clarity.';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Sports Nets Sourcing from India",
  "description": "Source sports nets from Indian manufacturers including football nets, cricket nets, volleyball nets, and custom sports netting.",
  "provider": { "@type": "Organization", "name": "Polyweave", "url": "https://polyweave.net" },
  "areaServed": ["Turkey", "Spain", "Italy", "Portugal", "Germany", "France", "Europe"],
  "serviceType": "Sourcing Service"
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonicalUrl="/sports-nets-manufacturer-india" schema={serviceSchema}>
  <Nav active="home" />

  <main id="main-content">
    <!-- Hero -->
    <section class="hero section-padding" style="position:relative;overflow:hidden">
      <InfiniteGrid hoverEffect={true} opacity={0.03} hoverOpacity={0.6} hoverRadius={300} />
      <div style="position:relative;z-index:1">
        <div class="max-w-content page-gutter">
          <div class="hero-eyebrow tag">SOURCING · INDIA → EUROPE</div>
          <h1 class="hero-title text-display-1">
            Sports Nets & Football Nets <span class="highlight-navy">from India</span>.
          </h1>
          <div class="hero-intro">
            <p>Polyweave helps buyers source sports nets from India for football, cricket, volleyball, tennis, handball, basketball and sports facility applications.</p>
            <p>We can also source boundary nets and custom nets for clubs, distributors and facility suppliers.</p>
            <p>Our current focus is on buyers in Turkey and Western Europe.</p>
          </div>
          <div class="europe-note tag">CURRENT FOCUS · TURKEY · WESTERN EUROPE</div>
        </div>
      </div>
    </section>

    <!-- What Matters -->
    <section class="what-matters section-padding">
      <div class="max-w-content page-gutter">
        <SectionTag num="02" label="FOOTBALL & CUSTOM SPORTS NETTING" />
        <h2 class="text-h2">Football nets are sized to the goal post.</h2>
        <p class="text-body-lg">
          Football nets are usually knotted and commonly made with braided material. A standard option is around 4 mm braided polyester, but the material and construction can be changed based on buyer requirements.
        </p>
        <p class="text-body">
          Overall size is one of the most important details. The common categories are large, medium and small goal nets, but custom sizes can also be developed.
        </p>
      </div>
    </section>

    <!-- Example Spec -->
    <section class="example-spec section-padding">
      <div class="max-w-content page-gutter">
        <SectionTag num="03" label="STANDARD FOOTBALL NET" />
        <div class="spec-card sketch-box-dashed">
          <span class="stamp">SAMPLE ONLY</span>
          <p class="spec-value">4 mm braided polyester · knotted · medium goal</p>
          <p class="spec-note text-body">Material, construction and size can all be changed based on the buyer requirement.</p>
        </div>
      </div>
    </section>

    <!-- What to Send -->
    <section class="what-to-send section-padding">
      <div class="max-w-content page-gutter">
        <SectionTag num="04" label="WHAT BUYERS SHOULD SEND" />
        <h2 class="text-h2">Tell us the net, the size, and the use case.</h2>
        <ul class="send-list">
          <li>Net type, overall size, mesh size, twine thickness, material, colour, knot type, UV requirement, packing and order quantity.</li>
        </ul>
        <p class="text-body">Polyweave helps match the buyer's requirement with Indian manufacturers who can supply at export-ready standards.</p>
      </div>
    </section>

    <!-- Final CTA -->
    <section class="final-cta section-padding bg-sea-blue">
      <div class="max-w-content page-gutter">
        <div class="cta-content">
          <h2 class="cta-title text-paper">Send your sports net requirement.</h2>
          <p class="text-paper-op-90">We'll review and respond with what's realistically possible from India.</p>
          <div class="cta-button">
            <a href={`${base}/contact`} class="btn-primary btn-paper">
              SEND YOUR PRICE <span class="btn-arrow">→</span>
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <StickyForm showBookCall={false} />
  <Footer />
</BaseLayout>

<style>
  .hero { min-height: 50vh; }
  .hero-eyebrow { margin-bottom: 16px; }
  .hero-title { margin-bottom: 24px; }
  .hero-intro { max-width: 720px; }
  .hero-intro p { font-size: 18px; line-height: 1.6; margin-bottom: 12px; color: var(--color-ink-soft); }
  .hero-intro p:last-child { margin-bottom: 0; }
  .europe-note { margin-top: 20px; }

  /* What Matters */
  .what-matters h2 { margin-bottom: 16px; }
  .what-matters p { max-width: 720px; color: var(--color-ink-soft); }
  .what-matters p:first-of-type { margin-bottom: 12px; }

  /* Example Spec */
  .spec-card { display: flex; flex-direction: column; gap: 12px; max-width: 600px; }
  .spec-value { font-family: var(--font-meta); font-size: 18px; color: var(--color-ink); margin: 0; }
  .spec-note { color: var(--color-ink-soft); margin: 0; }

  /* What to Send */
  .what-to-send h2 { margin-bottom: 16px; }
  .send-list { list-style: none; padding: 0; margin: 0 0 16px; max-width: 720px; }
  .send-list li { font-size: 18px; line-height: 1.6; color: var(--color-ink-soft); padding: 10px 0; border-bottom: 1px dashed rgba(20,35,58,0.2); }
  .what-to-send p { color: var(--color-ink-soft); }

  /* Final CTA */
  .cta-content { text-align: center; max-width: 600px; margin: 0 auto; }
  .cta-title { font-family: var(--font-display); font-size: 32px; margin: 0 0 12px; }
  .cta-content p { font-size: 18px; margin: 0 0 24px; }
  .cta-button { display: inline-block; }
  .btn-paper { background: var(--color-paper); color: var(--color-ink); }
  .btn-paper:hover { background: var(--color-paper-2); }
</style>
