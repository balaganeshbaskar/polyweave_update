---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import StickyForm from '../components/StickyForm.astro';
import SectionTag from '../components/SectionTag.astro';

const pageTitle = 'Nylon Fishing Net Supplier India | Monofilament & Multifilament Nets';
const pageDescription = 'Source nylon fishing nets from Indian manufacturers for commercial fishing applications. Polyweave helps European buyers import monofilament and multifilament nylon nets.';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Nylon Fishing Net Sourcing from India",
  "description": "Source nylon fishing nets from Indian manufacturers for commercial fishing applications including gill nets.",
  "provider": { "@type": "Organization", "name": "Polyweave", "url": "https://polyweave.net" },
  "areaServed": ["Spain", "Italy", "Portugal", "Germany", "France", "Norway", "Europe"],
  "serviceType": "Sourcing Service"
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonicalUrl="/nylon-net-supplier-india" schema={serviceSchema}>
  <Nav active="home" />

  <main id="main-content">
    <!-- Hero -->
    <section class="hero section-padding">
      <div class="max-w-content page-gutter">
        <div class="hero-eyebrow tag">SOURCING · INDIA → EUROPE</div>
        <h1 class="hero-title text-display-1">
          Nylon Fishing Net <span class="highlight-navy">Supplier</span> <span class="highlight-sea">from India</span>.
        </h1>
        <div class="hero-intro">
          <p>Polyweave helps buyers source nylon fishing nets from Indian manufacturers for commercial fishing applications, especially gill nets.</p>
          <p>We work with nylon monofilament and multifilament fishing nets, including depthway and lengthway stretching nylon nets. Knotless nets are not our focus.</p>
          <p>Nylon nets are used differently from HDPE or PE nets, so the application must be understood clearly before quoting.</p>
        </div>
        <div class="europe-note tag">WORKING WITH BUYERS ACROSS EUROPE · ES · IT · PT · DE · NO</div>
      </div>
    </section>

    <!-- What Matters -->
    <section class="what-matters section-padding">
      <div class="max-w-content page-gutter">
        <SectionTag num="02" label="STRONG NETS, CLEAR SPECS" />
        <h2 class="text-h2">For nylon, quality is the conversation.</h2>
        <p class="text-body-lg">
          Buyers usually need to provide the exact diameter, mesh size, depth, length, colour, stretching direction and packing requirement.
        </p>
        <p class="text-body">
          We work with manufacturers who can produce strong, high-quality nylon nets for fishing buyers who need consistency and durability.
        </p>
      </div>
    </section>

    <!-- Example Spec -->
    <section class="example-spec section-padding">
      <div class="max-w-content page-gutter">
        <SectionTag num="03" label="EXAMPLE SPECIFICATION" />
        <div class="spec-card sketch-box-dashed">
          <span class="stamp">SAMPLE ONLY</span>
          <p class="spec-value">0.30 x 50 mm x 50 MD x 1000 ML</p>
          <p class="spec-note text-body">This level of detail allows us to check the right supplier and avoid vague, unreliable pricing.</p>
        </div>
      </div>
    </section>

    <!-- What to Send -->
    <section class="what-to-send section-padding">
      <div class="max-w-content page-gutter">
        <SectionTag num="04" label="WHAT TO SEND US" />
        <h2 class="text-h2">Send your nylon net spec.</h2>
        <ul class="send-list">
          <li>Diameter, mesh size, depth, length, colour, stretching direction, packing and quantity.</li>
        </ul>
        <p class="text-body">Current supplier pricing helps us benchmark quickly. If you have a sample or photo, that works too.</p>
      </div>
    </section>

    <!-- Final CTA -->
    <section class="final-cta section-padding bg-sea-blue">
      <div class="max-w-content page-gutter">
        <div class="cta-content">
          <h2 class="cta-title text-paper">Send your nylon net spec.</h2>
          <p class="text-paper-op-90">We'll review and respond with what's realistically possible from India.</p>
          <div class="cta-button">
            <a href={`${base}/contact`} class="btn-primary btn-paper">
              SEND YOUR PRICE <span class="btn-arrow">→</span>
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <StickyForm showBookCall={false} />
  <Footer />
</BaseLayout>

<style>
  .hero { min-height: 50vh; }
  .hero-eyebrow { margin-bottom: 16px; }
  .hero-title { margin-bottom: 24px; }
  .hero-intro { max-width: 720px; }
  .hero-intro p { font-size: 18px; line-height: 1.6; margin-bottom: 12px; color: var(--color-ink-soft); }
  .hero-intro p:last-child { margin-bottom: 0; }
  .europe-note { margin-top: 20px; }

  /* What Matters */
  .what-matters h2 { margin-bottom: 16px; }
  .what-matters p { max-width: 720px; color: var(--color-ink-soft); }
  .what-matters p.text-body-lg { margin-bottom: 12px; }

  /* Example Spec */
  .spec-card { display: flex; flex-direction: column; gap: 12px; max-width: 600px; }
  .spec-value { font-family: var(--font-meta); font-size: 18px; color: var(--color-ink); margin: 0; }
  .spec-note { color: var(--color-ink-soft); margin: 0; }

  /* What to Send */
  .what-to-send h2 { margin-bottom: 16px; }
  .send-list { list-style: none; padding: 0; margin: 0 0 16px; max-width: 720px; }
  .send-list li { font-size: 18px; line-height: 1.6; color: var(--color-ink-soft); padding: 10px 0; border-bottom: 1px dashed rgba(20,35,58,0.2); }
  .what-to-send p { color: var(--color-ink-soft); }

  /* Final CTA */
  .cta-content { text-align: center; max-width: 600px; margin: 0 auto; }
  .cta-title { font-family: var(--font-display); font-size: 32px; margin: 0 0 12px; }
  .cta-content p { font-size: 18px; margin: 0 0 24px; }
  .cta-button { display: inline-block; }
  .btn-paper { background: var(--color-paper); color: var(--color-ink); }
  .btn-paper:hover { background: var(--color-paper-2); }
</style>
