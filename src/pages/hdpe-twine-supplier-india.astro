---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import StickyForm from '../components/StickyForm.astro';
import SectionTag from '../components/SectionTag.astro';

const pageTitle = 'HDPE Twine Supplier India | Source HDPE Twine for Europe';
const pageDescription = 'Source HDPE twine from trusted manufacturers in India. Polyweave helps European buyers reduce cost and risk when importing HDPE twine.';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "HDPE Twine Sourcing from India",
  "description": "Source HDPE twine from trusted manufacturers in India. Polyweave helps European buyers reduce cost and risk when importing HDPE twine.",
  "provider": {
    "@type": "Organization",
    "name": "Polyweave",
    "url": "https://polyweave.net"
  },
  "areaServed": ["Spain", "Italy", "Portugal", "Germany", "France", "Norway", "Europe"],
  "serviceType": "Sourcing Service"
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonicalUrl="/hdpe-twine-supplier-india" schema={serviceSchema}>
  <Nav active="home" />

  <main id="main-content">
    <!-- Hero -->
    <section class="hero section-padding">
      <div class="max-w-content page-gutter">
        <div class="hero-eyebrow tag">SOURCING · INDIA → EUROPE</div>
        <h1 class="hero-title text-display-1">
          HDPE Twine <span class="highlight-navy">Supplier</span> <span class="highlight-sea">India</span>.
        </h1>
        <div class="hero-intro">
          <p>Many companies across Europe are now shifting part of their sourcing to India.</p>
          <p>HDPE twine is one of the product categories where the price difference is becoming difficult to ignore.</p>
          <p>If you are currently sourcing within Europe, there is a strong chance the same product can be manufactured in India more efficiently.</p>
          <p>The challenge is not finding suppliers. The challenge is finding suppliers that are reliable, consistent, and aligned with export expectations.</p>
        </div>
      </div>
    </section>

    <!-- Where Polyweave fits (navy block per handoff) -->
    <section class="where-fits section-padding bg-navy">
      <div class="max-w-content page-gutter">
        <div class="fits-content">
          <h2 class="fits-title text-paper">That's where <span class="text-sea-soft">Polyweave</span> comes in.</h2>
          <p class="text-paper-op-85">We work with trusted manufacturers across India and help European buyers source HDPE twine with more clarity and less risk.</p>
          <p class="text-paper-op-85">Instead of dealing with unknown factories or random sourcing platforms, buyers work through an existing supplier network that already understands export requirements.</p>
        </div>
      </div>
    </section>

    <!-- What we work with -->
    <section class="what-work section-padding">
      <div class="max-w-content page-gutter">
        <SectionTag num="02" label="WE REGULARLY WORK WITH" />

        <div class="work-list bg-sea-tint">
          <ul>
            <li>Coreless HDPE twine</li>
            <li>HDPE twine for fishing applications</li>
            <li>Custom specifications for European buyers</li>
            <li>Industrial twine requirements</li>
            <li>Export-grade HDPE twine production</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Countries -->
    <section class="countries section-padding">
      <div class="max-w-content page-gutter">
        <div class="countries-grid">
          <div class="country-list">
            <span class="country-item">Spain</span>
            <span class="country-item country-sea">Italy</span>
            <span class="country-item">Portugal</span>
            <span class="country-item country-sea">Germany</span>
            <span class="country-item">France</span>
            <span class="country-item country-sea">Norway</span>
            <span class="country-more">— & other parts of Europe</span>
          </div>
          <div class="country-support">
            <p>Many of the companies we work with are looking to reduce sourcing costs while maintaining stable supply and product consistency.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Our role -->
    <section class="our-role section-padding">
      <div class="max-w-content page-gutter">
        <div class="role-grid">
          <div class="role-content">
            <h2 class="text-h2">Better sourcing, fewer problems.</h2>
            <p>Our role is simple. We help identify the right supplier, align pricing, verify expectations, and simplify communication between both sides.</p>
            <p>The objective is not just lower pricing. It is better sourcing with fewer problems.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Final CTA (sea-blue band per handoff) -->
    <section class="final-cta section-padding bg-sea-blue">
      <div class="max-w-content page-gutter">
        <div class="cta-content">
          <h2 class="cta-title text-paper">Already sourcing HDPE twine?</h2>
          <p class="text-paper-op-90">Send us your current price or specification.</p>
          <p class="cta-sub text-paper-op-75">We will tell you what is realistically possible.</p>
          <div class="cta-button">
            <a href={`${base}/contact`} class="btn-primary btn-paper">
              SEND YOUR PRICE <span class="btn-arrow">→</span>
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <StickyForm showBookCall={false} />
  <Footer />
</BaseLayout>

<style>
  .hero {
    min-height: 50vh;
  }

  .hero-eyebrow {
    margin-bottom: 16px;
  }

  .hero-title {
    margin-bottom: 24px;
  }

  .hero-intro {
    max-width: 720px;
  }

  .hero-intro p {
    font-size: 18px;
    line-height: 1.6;
    margin-bottom: 12px;
    color: var(--color-ink-soft);
  }

  .hero-intro p:last-child {
    margin-bottom: 0;
  }

  .highlight-navy {
    background: var(--color-ink);
    color: var(--color-paper);
    padding: 1px 6px;
    border-radius: 3px;
  }

  .highlight-sea {
    color: var(--color-sea);
  }

  /* Where fits */
  .fits-content {
    max-width: 800px;
  }

  .fits-title {
    font-family: var(--font-display);
    font-size: 32px;
    margin: 0 0 16px;
  }

  .fits-content p {
    font-size: 17px;
    line-height: 1.6;
    margin-bottom: 12px;
  }

  .fits-content p:last-child {
    margin-bottom: 0;
  }

  /* What we work with */
  .work-list {
    padding: 24px;
    border-radius: var(--radius-sketch);
  }

  .work-list ul {
    display: grid;
    grid-template-columns: 1fr;
    gap: 8px;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  @media (min-width: 768px) {
    .work-list ul {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .work-list li {
    font-size: 16px;
    padding: 4px 0;
  }

  .work-list li::before {
    content: "· ";
    color: var(--color-sea);
  }

  /* Countries */
  .countries-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }

  @media (min-width: 768px) {
    .countries-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .country-list {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .country-item {
    font-family: var(--font-display);
    font-size: 24px;
  }

  .country-sea {
    color: var(--color-sea);
  }

  .country-more {
    font-family: var(--font-body);
    font-size: 16px;
    color: var(--color-ink-faint);
    margin-top: 8px;
  }

  .country-support p {
    font-size: 17px;
    line-height: 1.6;
    color: var(--color-ink-soft);
  }

  /* Our role */
  .role-content p {
    font-size: 17px;
    line-height: 1.6;
    margin-bottom: 12px;
    max-width: 720px;
  }

  .role-content p:last-child {
    margin-bottom: 0;
  }

  /* Final CTA */
  .cta-content {
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
  }

  .cta-title {
    font-family: var(--font-display);
    font-size: 32px;
    margin: 0 0 12px;
  }

  .cta-content p {
    font-size: 18px;
    margin: 0 0 8px;
  }

  .cta-sub {
    margin-bottom: 24px;
  }

  .cta-button {
    display: inline-block;
  }

  .btn-paper {
    background: var(--color-paper);
    color: var(--color-ink);
  }

  .btn-paper:hover {
    background: var(--color-paper-2);
  }
</style>