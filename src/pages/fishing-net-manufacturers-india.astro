---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import StickyForm from '../components/StickyForm.astro';
import SectionTag from '../components/SectionTag.astro';
import InfiniteGrid from '../components/InfiniteGrid.astro';

const pageTitle = 'Fishing Net Manufacturers India | PE & Nylon Fishing Nets';
const pageDescription = 'Source custom fishing nets from Indian manufacturers for commercial fishing, aquaculture and marine use. Polyweave helps European buyers find the right mesh, twine and knot configuration.';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Fishing Net Sourcing from India",
  "description": "Source custom fishing nets from Indian manufacturers for commercial fishing, aquaculture and marine use.",
  "provider": { "@type": "Organization", "name": "Polyweave", "url": "https://polyweave.net" },
  "areaServed": ["Spain", "Italy", "Portugal", "Germany", "France", "Norway", "Europe"],
  "serviceType": "Sourcing Service"
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonicalUrl="/fishing-net-manufacturers-india" schema={serviceSchema}>
  <Nav active="home" />

  <main id="main-content">
    <!-- Hero -->
    <section class="hero section-padding" style="position:relative;overflow:hidden">
      <InfiniteGrid hoverEffect={true} opacity={0.03} hoverOpacity={0.6} hoverRadius={300} />
      <div style="position:relative;z-index:1">
        <div class="max-w-content page-gutter">
          <div class="hero-eyebrow tag">SOURCING · INDIA → EUROPE</div>
          <h1 class="hero-title text-display-1">
            Fishing Net <span class="highlight-navy">Manufacturers</span> <span class="highlight-sea">from India</span>.
          </h1>
          <div class="hero-intro">
            <p>Polyweave helps fishing equipment buyers source custom fishing nets from India for commercial fishing, aquaculture and general marine use.</p>
            <p>We can work with HDPE, PE and nylon fishing nets in different mesh sizes, twine thicknesses, depths, lengths, colours and knot types.</p>
            <p>Pricing is usually calculated per kg, which is the industry standard for many fishing net orders.</p>
          </div>
          <div class="europe-note tag">WORKING WITH BUYERS ACROSS EUROPE · ES · IT · PT · DE · NO</div>
        </div>
      </div>
    </section>

    <!-- What Matters -->
    <section class="what-matters section-padding">
      <div class="max-w-content page-gutter">
        <SectionTag num="02" label="BUILT AROUND YOUR EXACT SPEC" />
        <h2 class="text-h2">Vague details can't be quoted properly.</h2>
        <p class="text-body-lg">
          Mesh size, twine thickness, stretched depth, length, colour, knot type and finishing all change the price and final performance.
        </p>
        <p class="text-body">
          One common issue in poor-quality nets is slipping knots. For fishing buyers, this can create serious problems because the net does not hold properly during use.
        </p>
        <p class="text-body">
          Polyweave works with manufacturers who can produce both standard and custom fishing nets based on the buyer's exact requirement.
        </p>
      </div>
    </section>

    <!-- Example Spec -->
    <section class="example-spec section-padding">
      <div class="max-w-content page-gutter">
        <SectionTag num="03" label="EXAMPLE SPECIFICATION" />
        <div class="spec-card sketch-box-dashed">
          <span class="stamp">SAMPLE ONLY</span>
          <p class="spec-value">2.5 mm x 120 mm x 199.5 MD x 850 ML braided PE nets</p>
          <p class="spec-note text-body">This is the kind of detail that helps us compare suppliers properly and avoid incorrect quotes.</p>
        </div>
      </div>
    </section>

    <!-- What to Send -->
    <section class="what-to-send section-padding">
      <div class="max-w-content page-gutter">
        <SectionTag num="04" label="WHAT TO SEND US" />
        <h2 class="text-h2">Send your fishing net specification.</h2>
        <ul class="send-list">
          <li>Mesh size, twine thickness, stretched depth, length, colour, knot type, packing and quantity.</li>
        </ul>
        <p class="text-body">Add your current supplier pricing if you have it. The more specific you are, the faster we can come back with a realistic sourcing option.</p>
      </div>
    </section>

    <!-- Final CTA -->
    <section class="final-cta section-padding bg-sea-blue">
      <div class="max-w-content page-gutter">
        <div class="cta-content">
          <h2 class="cta-title text-paper">Send your fishing net specification.</h2>
          <p class="text-paper-op-90">We'll review and respond with what's realistically possible from India.</p>
          <div class="cta-button">
            <a href={`${base}/contact`} class="btn-primary btn-paper">
              SEND YOUR PRICE <span class="btn-arrow">→</span>
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <StickyForm showBookCall={false} showCallOnly={true} />
  <Footer />
</BaseLayout>

<style>
  .hero { min-height: 50vh; }
  .hero-eyebrow { margin-bottom: 16px; }
  .hero-title { margin-bottom: 24px; }
  .hero-intro { max-width: 720px; }
  .hero-intro p { font-size: 18px; line-height: 1.6; margin-bottom: 12px; color: var(--color-ink-soft); }
  .hero-intro p:last-child { margin-bottom: 0; }
  .europe-note { margin-top: 20px; }

  /* What Matters */
  .what-matters h2 { margin-bottom: 16px; }
  .what-matters p { max-width: 720px; color: var(--color-ink-soft); }
  .what-matters p.text-body-lg { margin-bottom: 12px; }
  .what-matters p.text-body { margin-bottom: 8px; }
  .what-matters p.text-body:last-child { margin-bottom: 0; }

  /* Example Spec */
  .spec-card { display: flex; flex-direction: column; gap: 12px; max-width: 600px; }
  .spec-value { font-family: var(--font-meta); font-size: 18px; color: var(--color-ink); margin: 0; }
  .spec-note { color: var(--color-ink-soft); margin: 0; }

  /* What to Send */
  .what-to-send h2 { margin-bottom: 16px; }
  .send-list { list-style: none; padding: 0; margin: 0 0 16px; max-width: 720px; }
  .send-list li { font-size: 18px; line-height: 1.6; color: var(--color-ink-soft); padding: 10px 0; border-bottom: 1px dashed rgba(20,35,58,0.2); }
  .what-to-send p { color: var(--color-ink-soft); }

  /* Final CTA */
  .cta-content { text-align: center; max-width: 600px; margin: 0 auto; }
  .cta-title { font-family: var(--font-display); font-size: 32px; margin: 0 0 12px; }
  .cta-content p { font-size: 18px; margin: 0 0 24px; }
  .cta-button { display: inline-block; }
  .btn-paper { background: var(--color-paper); color: var(--color-ink); }
  .btn-paper:hover { background: var(--color-paper-2); }
</style>
