---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import StickyForm from '../components/StickyForm.astro';
import SectionTag from '../components/SectionTag.astro';

const pageTitle = 'Rope Suppliers India | Polysteel, PP, HDPE, Polyester & Nylon Ropes';
const pageDescription = 'Source industrial and marine ropes from Indian manufacturers. Polyweave helps European buyers import polysteel, PP, HDPE, polyester and nylon ropes.';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Rope Sourcing from India",
  "description": "Source polysteel, PP, HDPE, polyester and nylon ropes from Indian manufacturers for fishing, marine, industrial and sports use.",
  "provider": { "@type": "Organization", "name": "Polyweave", "url": "https://polyweave.net" },
  "areaServed": ["Spain", "Italy", "Portugal", "Germany", "France", "Norway", "Europe"],
  "serviceType": "Sourcing Service"
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonicalUrl="/rope-suppliers-india" schema={serviceSchema}>
  <Nav active="home" />

  <main id="main-content">
    <!-- Hero -->
    <section class="hero section-padding">
      <div class="max-w-content page-gutter">
        <div class="hero-eyebrow tag">SOURCING · INDIA → EUROPE</div>
        <h1 class="hero-title text-display-1">
          Rope <span class="highlight-navy">Suppliers</span> <span class="highlight-sea">from India</span>.
        </h1>
        <div class="hero-intro">
          <p>Polyweave helps buyers source ropes from Indian manufacturers for fishing, marine, aquaculture, agriculture, sports and industrial use.</p>
          <p>We can source polysteel, PP, HDPE, polyester and nylon ropes in different constructions, including 3-strand, 4-strand, 8-strand and braided ropes.</p>
          <p>So far, our strongest experience has been with polysteel ropes.</p>
        </div>
        <div class="europe-note tag">WORKING WITH BUYERS ACROSS EUROPE · ES · IT · PT · DE · NO</div>
      </div>
    </section>

    <!-- What Matters -->
    <section class="what-matters section-padding">
      <div class="max-w-content page-gutter">
        <SectionTag num="02" label="BEYOND PRICE PER KG" />
        <h2 class="text-h2">The cheapest offer is not the best offer.</h2>
        <p class="text-body-lg">
          Diameter, construction, breaking strength, coil length, UV coating, packing, documentation and consistency all matter.
        </p>
        <p class="text-body">
          All ropes can be supplied with UV coating depending on the requirement.
        </p>
        <p class="text-body">
          Where needed, suppliers can provide ISO-certified production, MTC and certificate of origin.
        </p>
      </div>
    </section>

    <!-- Example Spec -->
    <section class="example-spec section-padding">
      <div class="max-w-content page-gutter">
        <SectionTag num="03" label="EXAMPLE ROPE REQUIREMENT" />
        <div class="spec-card sketch-box-dashed">
          <span class="stamp">SAMPLE ONLY</span>
          <p class="spec-value">16 mm 3-strand polysteel rope · 220 m coils · export packing</p>
          <p class="spec-note text-body">Polyweave helps compare Indian rope suppliers properly so buyers can improve pricing without losing control over quality.</p>
        </div>
      </div>
    </section>

    <!-- What to Send -->
    <section class="what-to-send section-padding">
      <div class="max-w-content page-gutter">
        <SectionTag num="04" label="WHAT TO SEND US" />
        <h2 class="text-h2">Send your rope spec and current price.</h2>
        <ul class="send-list">
          <li>Diameter, material, construction (3-strand / 4-strand / 8-strand / braided), MBS, coil length, UV requirement, packing and quantity.</li>
        </ul>
        <p class="text-body">Plus your current supplier price if available. Certifications needed (ISO, MTC, COO) — flag those upfront.</p>
      </div>
    </section>

    <!-- Final CTA -->
    <section class="final-cta section-padding bg-sea-blue">
      <div class="max-w-content page-gutter">
        <div class="cta-content">
          <h2 class="cta-title text-paper">Send your rope spec and current price.</h2>
          <p class="text-paper-op-90">We'll review and respond with what's realistically possible from India.</p>
          <div class="cta-button">
            <a href={`${base}/contact`} class="btn-primary btn-paper">
              SEND YOUR PRICE <span class="btn-arrow">→</span>
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <StickyForm showBookCall={false} />
  <Footer />
</BaseLayout>

<style>
  .hero { min-height: 50vh; }
  .hero-eyebrow { margin-bottom: 16px; }
  .hero-title { margin-bottom: 24px; }
  .hero-intro { max-width: 720px; }
  .hero-intro p { font-size: 18px; line-height: 1.6; margin-bottom: 12px; color: var(--color-ink-soft); }
  .hero-intro p:last-child { margin-bottom: 0; }
  .europe-note { margin-top: 20px; }
  .highlight-navy { background: var(--color-ink); color: var(--color-paper); padding: 1px 6px; border-radius: 3px; }
  .highlight-sea { color: var(--color-sea); }

  /* What Matters */
  .what-matters h2 { margin-bottom: 16px; }
  .what-matters p { max-width: 720px; color: var(--color-ink-soft); }
  .what-matters p.text-body-lg { margin-bottom: 12px; }
  .what-matters p.text-body { margin-bottom: 8px; }
  .what-matters p.text-body:last-child { margin-bottom: 0; }

  /* Example Spec */
  .spec-card { display: flex; flex-direction: column; gap: 12px; max-width: 600px; }
  .spec-value { font-family: var(--font-meta); font-size: 18px; color: var(--color-ink); margin: 0; }
  .spec-note { color: var(--color-ink-soft); margin: 0; }

  /* What to Send */
  .what-to-send h2 { margin-bottom: 16px; }
  .send-list { list-style: none; padding: 0; margin: 0 0 16px; max-width: 720px; }
  .send-list li { font-size: 18px; line-height: 1.6; color: var(--color-ink-soft); padding: 10px 0; border-bottom: 1px dashed rgba(20,35,58,0.2); }
  .what-to-send p { color: var(--color-ink-soft); }

  /* Final CTA */
  .cta-content { text-align: center; max-width: 600px; margin: 0 auto; }
  .cta-title { font-family: var(--font-display); font-size: 32px; margin: 0 0 12px; }
  .cta-content p { font-size: 18px; margin: 0 0 24px; }
  .cta-button { display: inline-block; }
  .btn-paper { background: var(--color-paper); color: var(--color-ink); }
  .btn-paper:hover { background: var(--color-paper-2); }
</style>
